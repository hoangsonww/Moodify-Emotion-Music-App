# Moodify Modal inference service -- required environment.
#
# In production these are stored in a Modal Secret named "moodify-secrets":
#   modal secret create moodify-secrets \
#     SPOTIFY_CLIENT_ID=... SPOTIFY_CLIENT_SECRET=... \
#     HF_TEXT_MODEL_REPO=... JWT_SIGNING_KEY=... \
#     MODAL_SERVICE_TOKEN=... ALLOWED_ORIGINS=...
#
# Copy this file to .env for local `modal serve` runs. Never commit .env.

# Spotify Web API (client-credentials flow)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Hugging Face repo holding the fine-tuned text-emotion model
# (download_models.py pulls it into the Modal Volume). HF_TOKEN is only
# needed if that repo is private.
HF_TEXT_MODEL_REPO=your-hf-username/moodify-text-emotion
HF_TOKEN=

# Shared HS256 key -- MUST match Django's SIMPLE_JWT["SIGNING_KEY"].
# Django signs end-user JWTs with it; Modal verifies them with it.
JWT_SIGNING_KEY=

# Shared secret for trusted Django -> Modal proxy calls.
MODAL_SERVICE_TOKEN=

# Comma-separated browser origins allowed by CORS. Leave empty to allow
# all origins (e.g. https://moodify.vercel.app,http://localhost:3000).
ALLOWED_ORIGINS=
