# Moodify Django API -- environment variables.
# Copy to backend/.env for local development; set as project env vars on
# Vercel for production. Never commit the real .env.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=.vercel.app,localhost,127.0.0.1

# --- MongoDB Atlas (the only datastore) ---
MONGO_DB_URI=mongodb+srv://cluster.example.mongodb.net
MONGO_DB_NAME=emotion_based_music_db
MONGO_DB_USERNAME=
MONGO_DB_PASSWORD=

# --- JWT (shared with the Modal inference service) ---
# JWT_SIGNING_KEY MUST match modal_inference's JWT_SIGNING_KEY.
JWT_SIGNING_KEY=change-me-shared-with-modal
JWT_ACCESS_TOKEN_DAYS=7
JWT_REFRESH_TOKEN_DAYS=14

# --- WebAuthn / passkeys ---
# RP ID MUST be the bare domain the FRONTEND is served from (no scheme/port).
# For local dev that's "localhost"; in production set it to your frontend host
# e.g. moodify-app.vercel.app. EXPECTED_ORIGINS is the comma-separated list of
# full origins allowed to finish a ceremony (scheme + host + optional port).
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Moodify
WEBAUTHN_EXPECTED_ORIGINS=http://localhost:3000,http://localhost:3001
WEBAUTHN_CHALLENGE_TTL_SECONDS=300

# --- Modal inference service ---
MODAL_INFERENCE_URL=https://your-org--moodify-inference-inferenceservice-web.modal.run
# MODAL_SERVICE_TOKEN MUST match modal_inference's MODAL_SERVICE_TOKEN.
MODAL_SERVICE_TOKEN=change-me-shared-with-modal

# --- CORS ---
# All origins are allowed by default. To restrict, uncomment both:
#   CORS_ALLOW_ALL_ORIGINS=False
#   CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# --- Optional: shared cache (serverless Redis, e.g. Upstash) ---
CACHE_REDIS_URL=

# --- Optional: API throttling rates ---
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
