# Moodify mobile app -- environment variables (Expo).
# Copy to mobile/.env. Only EXPO_PUBLIC_* vars are exposed to the app.

# Django REST API (auth, profiles/history, text + music).
EXPO_PUBLIC_API_URL=https://your-django-api.vercel.app

# Modal ML inference service (speech + facial emotion, direct upload).
EXPO_PUBLIC_MODAL_API_URL=https://your-org--moodify-inference-inferenceservice-web.modal.run
