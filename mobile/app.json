{
  "expo": {
    "name": "Moodify",
    "slug": "moodify-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "moodify",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moodify.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f14"
      },
      "package": "com.moodify.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "Moodify uses the camera to detect your mood from a photo." }
      ],
      [
        "expo-av",
        { "microphonePermission": "Moodify uses the microphone to detect your mood from your voice." }
      ]
    ]
  }
}
