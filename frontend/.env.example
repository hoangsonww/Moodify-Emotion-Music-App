# Moodify web frontend -- environment variables (Create React App).
# Copy to frontend/.env. Only REACT_APP_* vars are exposed to the build.

# Django REST API (auth, profiles/history, text + music). The Vercel
# deployment URL in production.
REACT_APP_API_URL=https://your-django-api.vercel.app

# Modal ML inference service (speech + facial emotion, direct upload).
REACT_APP_MODAL_API_URL=https://your-org--moodify-inference-inferenceservice-web.modal.run
